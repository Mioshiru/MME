{
    "version": 3,
    "configurePresets": [
        {
            "name": "windows-vcpkg",
            "displayName": "Windows x64 (vcpkg)",
            "generator": "Visual Studio 17 2022",
            "architecture": "x64",
            "binaryDir": "${sourceDir}/build",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/cmake/vcpkg-toolchain.cmake",
                "VCPKG_TARGET_TRIPLET": "x64-windows"
            }
        }
    ]
}